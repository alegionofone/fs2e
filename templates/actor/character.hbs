<form class="{{cssClass}} fs2e sheet actor character actor-sheet {{#if view.sheetLock.locked}}fs2e-sheet-locked{{/if}}" autocomplete="off">
	<header class="sheet-header fs2e-grid-sheet-header">
		<img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />

		<div class="header-fields">
			<h1 class="sheetname">
				<input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
			</h1>

			<div class="header container shade">
				<div class="fs2e-grid-sheet-fields">
					<label class="field underline">
						<span class="label">Player</span>
						<input name="system.player" type="text" value="{{system.player}}" />
					</label>

					<label class="field underline species-field" data-drop-species>
						<span class="label">Species</span>
						<div class="data-pill">
							{{#if view.species}}
								<a class="open-species" data-uuid="{{view.species.uuid}}">{{view.species.name}}</a>
								<a class="clear-species" title="Clear">x</a>
							{{else}}
								<span class="placeholder">Drop species item here</span>
							{{/if}}
						</div>
					</label>

					<div class="fs2e-grid-sheet-age">
						<label class="field underline">
							<span class="label">Age</span>
							<input name="system.age" type="text" value="{{system.age}}" />
						</label>

						<label class="field underline">
							<span class="label">Gender</span>
							<input name="system.gender" type="text" value="{{system.gender}}" />
						</label>
					</div>

					<label class="field underline planet-field" data-drop-planet>
						<span class="label">Planet</span>
						<div class="data-pill">
							{{#if view.planet}}
								<a class="open-planet" data-uuid="{{view.planet.uuid}}">{{view.planet.name}}</a>
								<a class="clear-planet" title="Clear">x</a>
							{{else}}
								<span class="placeholder">Drop planet item here</span>
							{{/if}}
						</div>
					</label>

					<label class="field underline aliance-field" data-drop-faction>
						<span class="label">Alliance</span>
						<div class="data-pill">
							{{#if view.faction}}
								<a class="open-faction" data-uuid="{{view.faction.uuid}}">{{view.faction.name}}</a>
								<a class="clear-faction" title="Clear">x</a>
							{{else}}
								<span class="placeholder">Drop alliance item here</span>
							{{/if}}
						</div>
					</label>

					<label class="field underline">
						<span class="label">Rank</span>
						<input type="text" name="system.rank" value="{{system.rank}}" />
					</label>
				</div>
			</div>
		</div>
	</header>

	<nav class="sheet-tabs tabs actor" data-group="primary">
		<a class="item" data-tab="characteristics" title="Traits" aria-label="Traits"><i class="fa-solid fa-user"></i><span class="sr-only">Traits</span></a>
		<a class="item" data-tab="qualities" title="Qualities" aria-label="Qualities"><i class="fa-solid fa-star"></i><span class="sr-only">Qualities</span></a>
		<a class="item" data-tab="actions" title="Actions" aria-label="Actions"><i class="fa-solid fa-hand"></i><span class="sr-only">Actions</span></a>
		<a class="item" data-tab="combat" title="Combat" aria-label="Combat"><i class="fa-solid fa-sword"></i><span class="sr-only">Combat</span></a>
		<a class="item" data-tab="traits" title="Traits" aria-label="Traits"><i class="fa-solid fa-tag"></i><span class="sr-only">Traits</span></a>
		<a class="item" data-tab="effects" title="Effects" aria-label="Effects"><i class="fa-solid fa-wand-magic-sparkles"></i><span class="sr-only">Effects</span></a>
		<a class="item" data-tab="equipment" title="Equipment" aria-label="Equipment"><i class="fa-solid fa-briefcase"></i><span class="sr-only">Equipment</span></a>
		<a class="item" data-tab="biography" title="Biography" aria-label="Biography"><i class="fa-solid fa-book-open"></i><span class="sr-only">Biography</span></a>
	</nav>

	<section class="sheet-body">
		<div class="tab characteristics" data-group="primary" data-tab="characteristics">
			{{> "systems/fs2e/templates/actor/actor-tabs/characteristics-tab.hbs"}}
		</div>

		<div class="tab qualities traits" data-group="primary" data-tab="qualities">
			{{> "systems/fs2e/templates/actor/actor-tabs/qualities-tab.hbs"}}
			<section class="container shade traits-section" data-collapsible-section data-collapsed="0">
				<h3>Blessings and Curses</h3>
				<p class="traits-section-note">These are inherited options only. Their bonuses are not permanently applied here unless they are always active.</p>
				<table class="traits-table combat-actions-table fs2e-bc-table">
					<thead><tr><th>Title</th><th class="traits-points-head">Points</th><th>Effect</th><th></th></tr></thead>
					<tbody>
						{{#if view.blessingCurses.length}}
							<tr class="fs2e-bc-section-row {{#unless view.blessingCurseSections.blessingsExpanded}}is-collapsed{{/unless}}" data-action="toggle-bc-section" data-section="blessings">
								<td colspan="4"><span class="fs2e-bc-section-text">Blessings</span><span class="fs2e-bc-section-icon" aria-hidden="true"></span></td>
							</tr>
							{{#if view.blessingCurseSections.blessingsExpanded}}
							{{#if view.blessings.length}}
								{{#each view.blessings}}
									<tr class="fs2e-bc-item-row">
										<td>
											{{#if this.hasUuid}}
												<a class="open-bonus-blessing-curse" data-uuid="{{this.uuid}}">{{this.name}}</a>
											{{else}}
												{{this.name}}
											{{/if}}
										</td>
										<td class="traits-points-cell">{{#if this.points}}{{this.points}}{{else}}-{{/if}}</td>
										<td>{{#if this.effect}}{{this.effect}}{{else}}-{{/if}}</td>
										<td class="traits-open-cell"></td>
									</tr>
								{{/each}}
							{{else}}
								<tr class="traits-empty-row fs2e-bc-item-row"><td colspan="4">No blessings.</td></tr>
							{{/if}}
							{{/if}}

							<tr class="fs2e-bc-section-row {{#unless view.blessingCurseSections.cursesExpanded}}is-collapsed{{/unless}}" data-action="toggle-bc-section" data-section="curses">
								<td colspan="4"><span class="fs2e-bc-section-text">Curses</span><span class="fs2e-bc-section-icon" aria-hidden="true"></span></td>
							</tr>
							{{#if view.blessingCurseSections.cursesExpanded}}
							{{#if view.curses.length}}
								{{#each view.curses}}
									<tr class="fs2e-bc-item-row">
										<td>
											{{#if this.hasUuid}}
												<a class="open-bonus-blessing-curse" data-uuid="{{this.uuid}}">{{this.name}}</a>
											{{else}}
												{{this.name}}
											{{/if}}
										</td>
										<td class="traits-points-cell">{{#if this.points}}{{this.points}}{{else}}-{{/if}}</td>
										<td>{{#if this.effect}}{{this.effect}}{{else}}-{{/if}}</td>
										<td class="traits-open-cell"></td>
									</tr>
								{{/each}}
							{{else}}
								<tr class="traits-empty-row fs2e-bc-item-row"><td colspan="4">No curses.</td></tr>
							{{/if}}
							{{/if}}
						{{else}}
							<tr class="traits-empty-row"><td colspan="4">No blessings or curses.</td></tr>
						{{/if}}
					</tbody>
				</table>
			</section>
			<section class="container shade traits-section" data-collapsible-section data-collapsed="0">
				<h3>Benefices and Afflictions</h3>
				<table class="traits-table combat-actions-table">
					<thead><tr><th>Title</th><th class="traits-points-head">Points</th><th>Effect</th><th></th></tr></thead>
					<tbody><tr class="traits-empty-row"><td colspan="4">Front-end shell only. Backend data wiring pending.</td></tr></tbody>
				</table>
			</section>
		</div>

		<div class="tab equipment traits" data-group="primary" data-tab="equipment">
			<section class="container shade traits-section" data-collapsible-section data-collapsed="0">
				<h3>Weapons</h3>
				<table class="traits-table combat-actions-table equipment-weapons-table">
					<thead><tr><th>Melee Weapon</th><th>Roll</th><th class="traits-points-head">Init</th><th class="traits-points-head">Goal</th><th class="traits-points-head">DMG</th><th class="traits-points-head">STR</th><th class="traits-points-head">SIZ</th><th class="traits-points-head">Cost</th></tr></thead>
					<tbody><tr class="traits-empty-row"><td colspan="8">Front-end shell only.</td></tr></tbody>
				</table>
			</section>
		</div>

		<div class="tab combat traits" data-group="primary" data-tab="combat">
			<section class="container shade traits-section" data-collapsible-section data-collapsed="0">
				<h3>Combat Actions</h3>
				<table class="traits-table combat-actions-table">
					<thead><tr><th>Action</th><th class="traits-points-head">LVL</th><th>Roll</th><th class="traits-points-head">Goal</th><th class="traits-points-head">Init</th><th class="traits-points-head">DMG</th><th></th></tr></thead>
					<tbody><tr class="traits-empty-row"><td colspan="7">Front-end shell only.</td></tr></tbody>
				</table>
			</section>
		</div>

		<div class="tab actions traits" data-group="primary" data-tab="actions">
			<section class="container shade traits-section" data-collapsible-section data-collapsed="0">
				<h3>Normal Actions</h3>
				<table class="traits-table combat-actions-table">
					<thead><tr><th>Action</th><th>Roll</th><th class="traits-points-head">Goal</th><th></th></tr></thead>
					<tbody><tr class="traits-empty-row"><td colspan="4">Front-end shell only.</td></tr></tbody>
				</table>
			</section>
		</div>

		<div class="tab traits" data-group="primary" data-tab="traits"></div>

		<div class="tab effects" data-group="primary" data-tab="effects">
			<section class="container shade traits-section"><h3>Effects</h3><p>Front-end shell only.</p></section>
		</div>

		<div class="tab biography" data-group="primary" data-tab="biography">
			<div class="container shade biography-grid grid cols-1 gap-sm">
				<h3>History</h3>
				{{#each view.histories}}
					<label class="field fs2e-history-row" data-drop-history data-history-slot="{{this.idx}}">
						<span class="label fs2e-history-slot-label">{{this.label}}:</span>
						<span class="fs2e-history-slot-value">
							{{#if this.uuid}}
								<span class="data-pill">
									<a class="open-history" data-uuid="{{this.uuid}}">{{this.name}}</a>
									<a class="clear-history" data-history-slot="{{this.idx}}" title="Clear">x</a>
								</span>
							{{else}}
								<span class="placeholder">Drop history item here</span>
							{{/if}}
						</span>
					</label>
				{{/each}}
			</div>
		</div>
	</section>
</form>
