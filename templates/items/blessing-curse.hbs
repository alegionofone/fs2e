<form class="{{cssClass}} fs2e-item-sheet {{#if view.sheetLock.locked}}fs2e-sheet-locked{{/if}}" autocomplete="off">
  {{> "systems/fs2e/templates/items/partials/item-header.hbs" }}

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="effect">Effect</a>
  </nav>

  <section class="sheet-body">
    {{> "systems/fs2e/templates/items/partials/item-description.hbs" }}

    <div class="tab" data-group="primary" data-tab="effect">
      <section class="item-section">
        <div class="blessing-curse-effect-grid">
          <span class="blessing-curse-effect-label">Bonus</span>
          <span class="blessing-curse-effect-label">Trait</span>
          <span class="blessing-curse-effect-label">Description</span>
          <span class="blessing-curse-effect-label">Points</span>

          <input
            class="traits-input blessing-curse-effect-input blessing-curse-effect-input-bonus"
            name="system.effectLine.amount"
            type="text"
            value="{{view.effectLine.amount}}"
            placeholder="+0"
          />

          <select class="blessing-curse-effect-input" name="system.effectLine.target">
            {{#select view.effectLine.target}}
              <option value=""></option>
              <optgroup label="Characteristics">
                {{#each view.characteristicTargets}}
                  <option value="{{this.value}}">{{this.label}}</option>
                {{/each}}
              </optgroup>
              <optgroup label="Skills">
                {{#each view.skillTargets}}
                  <option value="{{this.value}}">{{this.label}}</option>
                {{/each}}
              </optgroup>
              <optgroup label="Other Traits">
                {{#each view.otherTraitTargets}}
                  <option value="{{this.value}}">{{this.label}}</option>
                {{/each}}
              </optgroup>
            {{/select}}
          </select>

          <input
            class="blessing-curse-effect-input"
            name="system.effectLine.note"
            type="text"
            value="{{view.effectLine.note}}"
            placeholder="Description"
          />

          <input
            class="traits-input blessing-curse-effect-input blessing-curse-effect-input-points"
            name="system.points"
            type="text"
            value="{{view.points}}"
            placeholder="0"
          />
        </div>

        <label class="species-form-row blessing-curse-always-active-row">
          <span class="species-row-label">Always Active</span>
          <span class="species-row-value">
            <input name="system.alwaysActive" type="checkbox" {{#if view.alwaysActive}}checked{{/if}} />
          </span>
        </label>
      </section>
    </div>
  </section>
</form>
