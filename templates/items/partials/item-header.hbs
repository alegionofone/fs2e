<header class="sheet-header fs2e-item-header">
	<img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
	<div class="header-fields sheet-header-meta">
		<h1 class="item-name">
			<input name="name" type="text" value="{{item.name}}" placeholder="Name" />
		</h1>
		<div class="sheet-tags-slot">
			<div class="fs2e-tags fs2e-tag-surface">
				<input
					type="text"
					class="fs2e-tag-menu fs2e-tag-input fs2e-tagify-base"
					name="system.tags"
					value="{{itemTagsCsv}}"
					placeholder="Add tags"
				/>
			</div>
		</div>
	</div>
</header>
