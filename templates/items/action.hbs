<form class="{{cssClass}} fs2e-item-sheet {{#if view.sheetLock.locked}}fs2e-sheet-locked{{/if}}" autocomplete="off">
  {{> "systems/fs2e/templates/items/partials/item-header.hbs" }}

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="action">Action</a>
  </nav>

  <section class="sheet-body">
    {{> "systems/fs2e/templates/items/partials/item-description.hbs" }}

    <div class="tab" data-group="primary" data-tab="action">
      <section class="item-section fs2e-action-sheet-grid">
        <div class="fs2e-action-row">
          <label class="fs2e-action-cell fs2e-action-cell-level">
            <span class="fs2e-action-head">Level</span>
            <input class="traits-input" name="system.level" type="number" step="1" value="{{view.level}}" />
          </label>

          <div class="fs2e-action-cell fs2e-action-cell-roll">
            <span class="fs2e-action-head">Characteristic</span>
            <div class="fs2e-action-roll-fields">
              <select name="system.characteristic">
                {{#select view.characteristic}}
                  <option value=""></option>
                  {{#each view.characteristics}}
                    <option value="{{this.key}}">{{this.label}}</option>
                  {{/each}}
                {{/select}}
              </select>
              <span class="fs2e-action-plus">+</span>
              <select name="system.skill">
                {{#select view.skill}}
                  <option value=""></option>
                  {{#each view.skills}}
                    <option value="{{this.key}}">{{this.label}}</option>
                  {{/each}}
                {{/select}}
              </select>
            </div>
          </div>

          <label class="fs2e-action-cell fs2e-action-cell-compact">
            <span class="fs2e-action-head">Initiative</span>
            <input class="traits-input" name="system.init" type="text" value="{{view.init}}" />
          </label>

          <label class="fs2e-action-cell fs2e-action-cell-compact">
            <span class="fs2e-action-head">Goal</span>
            <input class="traits-input" name="system.goal" type="text" value="{{view.goal}}" />
          </label>

          <label class="fs2e-action-cell fs2e-action-cell-compact">
            <span class="fs2e-action-head">Damage</span>
            <input class="traits-input" name="system.dmg" type="number" step="1" value="{{view.dmg}}" />
          </label>
        </div>
      </section>
    </div>
  </section>
</form>
